rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config
    // Document ID: app-settings
    // Fields:
    //   - bgUrlDark: string (optional) - URL for dark mode background
    //   - bgUrlLight: string (optional) - URL for light mode background
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jeffsalon1998@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidConfig(data) {
      return (data.get('bgUrlDark', '') is string) &&
             (data.get('bgUrlLight', '') is string);
    }

    // Config rules
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin() && isValidConfig(request.resource.data);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
